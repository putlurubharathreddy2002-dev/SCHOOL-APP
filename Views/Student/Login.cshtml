@model SchoolApp.ViewModels.StudentLoginVM
@{
    Layout = "_Layout";
    ViewData["Title"] = "Student Login";
}

<div class="auth-page">
    <div class="auth-container auth-container-sm">
        <div class="auth-header student-header">
            <div class="auth-header-icon"><i class="bi bi-box-arrow-in-right"></i></div>
            <h1 class="auth-title">Student Login</h1>
            <p class="auth-subtitle">Welcome back! Sign in to your account</p>
        </div>

        <div class="auth-body">
            <form asp-action="Login" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div></div>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" id="loginEmail" placeholder="Email" autofocus />
                        <label asp-for="Email"><i class="bi bi-envelope me-1"></i>Email Address</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="form-floating">
                        <input asp-for="Password" class="form-control" id="loginPassword" placeholder="Password" />
                        <label asp-for="Password"><i class="bi bi-lock me-1"></i>Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-student btn-lg w-100 mt-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="auth-footer-link">
                Don't have an account? <a href="/Student/Register" class="link-student">Register here</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
