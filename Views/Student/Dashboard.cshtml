@model SchoolApp.Models.Student
@{
    Layout = "_Layout";
    ViewData["Title"] = "Student Dashboard";
}

<div class="dashboard-page">
    <div class="container py-5">

        <!-- Welcome Banner -->
        <div class="dashboard-banner student-banner mb-4">
            <div class="banner-avatar student-avatar">
                <i class="bi bi-person-circle"></i>
            </div>
            <div class="banner-info">
                <p class="banner-label">Welcome back,</p>
                <h1 class="banner-name">@Model.FullName</h1>
                <span class="badge badge-student"><i class="bi bi-mortarboard me-1"></i>Student</span>
            </div>
            <div class="banner-actions ms-auto">
                <form asp-controller="Student" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light">
                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </button>
                </form>
            </div>
        </div>

        <!-- Stats Row -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card student-stat">
                    <i class="bi bi-hash stat-icon"></i>
                    <div class="stat-value">@(string.IsNullOrEmpty(Model.RollNumber) ? "N/A" : Model.RollNumber)</div>
                    <div class="stat-label">Roll Number</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card student-stat">
                    <i class="bi bi-building stat-icon"></i>
                    <div class="stat-value">@(string.IsNullOrEmpty(Model.Department) ? "N/A" : Model.Department)</div>
                    <div class="stat-label">Department</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card student-stat">
                    <i class="bi bi-calendar-event stat-icon"></i>
                    <div class="stat-value">@(Model.EnrollmentYear == 0 ? "N/A" : Model.EnrollmentYear.ToString())</div>
                    <div class="stat-label">Enrollment Year</div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="stat-card student-stat">
                    <i class="bi bi-check-circle stat-icon"></i>
                    <div class="stat-value">Active</div>
                    <div class="stat-label">Account Status</div>
                </div>
            </div>
        </div>

        <!-- Full Profile Card -->
        <div class="profile-card">
            <div class="profile-card-header student-card-header">
                <h2><i class="bi bi-person-lines-fill me-2"></i>Profile Details</h2>
            </div>
            <div class="profile-card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-person-fill"></i></div>
                            <div>
                                <div class="detail-label">Full Name</div>
                                <div class="detail-value">@Model.FullName</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-envelope-fill"></i></div>
                            <div>
                                <div class="detail-label">Email Address</div>
                                <div class="detail-value">@Model.Email</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-telephone-fill"></i></div>
                            <div>
                                <div class="detail-label">Phone Number</div>
                                <div class="detail-value">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-building-fill"></i></div>
                            <div>
                                <div class="detail-label">Department</div>
                                <div class="detail-value">@(string.IsNullOrEmpty(Model.Department) ? "Not provided" : Model.Department)</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-tag-fill"></i></div>
                            <div>
                                <div class="detail-label">Roll Number</div>
                                <div class="detail-value">@(string.IsNullOrEmpty(Model.RollNumber) ? "Not provided" : Model.RollNumber)</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-calendar-fill"></i></div>
                            <div>
                                <div class="detail-label">Enrollment Year</div>
                                <div class="detail-value">@(Model.EnrollmentYear == 0 ? "Not provided" : Model.EnrollmentYear.ToString())</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-person-badge-fill"></i></div>
                            <div>
                                <div class="detail-label">Student ID</div>
                                <div class="detail-value">#@Model.Id.ToString("D6")</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-item">
                            <div class="detail-icon student-detail-icon"><i class="bi bi-clock-fill"></i></div>
                            <div>
                                <div class="detail-label">Member Since</div>
                                <div class="detail-value">@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
